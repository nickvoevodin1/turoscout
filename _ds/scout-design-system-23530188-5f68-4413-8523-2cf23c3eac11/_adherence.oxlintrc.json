{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/brand/**",
              "components/content/**",
              "components/controls/**",
              "components/typography/**",
              "ui_kits/scout/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Playfair Display|Lora))/i]",
        "message": "Font not provided by the design system. Available: Playfair Display, Lora."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:cream|line)$/]",
        "message": "<Badge> tone must be one of 'cream' | 'line'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|as|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, as, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:outline|solid|gold|ghost)$/]",
        "message": "<Button> variant must be one of 'outline' | 'solid' | 'gold' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Callout'] > JSXAttribute > JSXIdentifier[name!=/^(?:bar|children|key|ref|className|style|children)$/]",
        "message": "<Callout> doesn't accept that prop. Declared props: bar, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|number|title|tone|labelColor|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: label, number, title, tone, labelColor, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:surface|subtle|muted)$/]",
        "message": "<Card> tone must be one of 'surface' | 'subtle' | 'muted'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CheckList'] > JSXAttribute > JSXIdentifier[name!=/^(?:items|marker|columns|gap|children|key|ref|className|style|children)$/]",
        "message": "<CheckList> doesn't accept that prop. Declared props: items, marker, columns, gap, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='CheckList'] > JSXAttribute[name.name='marker'] > Literal[value!=/^(?:check|diamond)$/]",
        "message": "<CheckList> marker must be one of 'check' | 'diamond'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Divider'] > JSXAttribute > JSXIdentifier[name!=/^(?:spacing|key|ref|className|style|children)$/]",
        "message": "<Divider> doesn't accept that prop. Declared props: spacing."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute > JSXIdentifier[name!=/^(?:number|color|as|children|key|ref|className|style|children)$/]",
        "message": "<Eyebrow> doesn't accept that prop. Declared props: number, color, as, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Pill'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|children|key|ref|className|style|children)$/]",
        "message": "<Pill> doesn't accept that prop. Declared props: tone, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Pill'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:cream|ghost|solid)$/]",
        "message": "<Pill> tone must be one of 'cream' | 'ghost' | 'solid'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ScoutMark'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|color|tone|as|key|ref|className|style|children)$/]",
        "message": "<ScoutMark> doesn't accept that prop. Declared props: size, color, tone, as."
      },
      {
        "selector": "JSXOpeningElement[name.name='ScoutMark'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:ink|inverse)$/]",
        "message": "<ScoutMark> tone must be one of 'ink' | 'inverse'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeader'] > JSXAttribute > JSXIdentifier[name!=/^(?:number|eyebrow|title|lead|size|align|key|ref|className|style|children)$/]",
        "message": "<SectionHeader> doesn't accept that prop. Declared props: number, eyebrow, title, lead, size, align."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeader'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:hero|h1|h2)$/]",
        "message": "<SectionHeader> size must be one of 'hero' | 'h1' | 'h2'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeader'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|center)$/]",
        "message": "<SectionHeader> align must be one of 'left' | 'center'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SegmentOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<SegmentOption> doesn't accept that prop. Declared props: value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='Slider'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|defaultValue|min|max|step|onChange|format|key|ref|className|style|children)$/]",
        "message": "<Slider> doesn't accept that prop. Declared props: label, value, defaultValue, min, max, step, onChange, format."
      },
      {
        "selector": "JSXOpeningElement[name.name='SpecRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|labelWidth|children|key|ref|className|style|children)$/]",
        "message": "<SpecRow> doesn't accept that prop. Declared props: label, value, labelWidth, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stat'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|suffix|label|size|align|key|ref|className|style|children)$/]",
        "message": "<Stat> doesn't accept that prop. Declared props: value, suffix, label, size, align."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stat'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|center)$/]",
        "message": "<Stat> align must be one of 'left' | 'center'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
